PORT=3000
# Comma-separated allowed origins for the frontend. In production this MUST be
# set explicitly (no fallback is used) — e.g. CORS_ORIGINS=https://poke-guess-who.vercel.app
CORS_ORIGINS=http://localhost:3001
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
# Required for local dev (no longer defaults to this — its presence is what
# tells the app to use local dummy credentials instead of the production
# credential chain). Leave this UNSET in production so the AWS SDK picks up
# the EC2 instance role via IMDS instead.
DYNAMODB_ENDPOINT=http://127.0.0.1:8000
