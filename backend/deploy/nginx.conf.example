# Reference copy only — the real file lives on the EC2 instance at
# /etc/nginx/conf.d/pokeguess.conf with the actual hostname filled in.
# Installed/managed via `certbot --nginx`, which rewrites this to add the
# 443 listener, cert paths, and HTTP->HTTPS redirect automatically.

server {
    listen 80;
    server_name ec2-XX-XX-XX-XX.us-east-1.compute.amazonaws.com;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /ws {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # Long-lived game connections shouldn't be force-closed by the proxy —
        # the app's own connection registry/ping logic governs real liveness.
        proxy_read_timeout 3600s;
    }
}
